#!/usr/bin/env bash
#ddev-generated
## Description: Scaffold Playwright test structure into the project
## Usage: playwright-init
## Example: "ddev playwright-init"

cd /var/www/html || exit 1

# Scaffold project structure from .ddev/scaffold (mounted at /mnt/ddev_config/scaffold)
SCAFFOLD_DIR="/mnt/ddev_config/scaffold"

if [ ! -d "$SCAFFOLD_DIR" ]; then
    echo "Error: scaffold directory not found at $SCAFFOLD_DIR"
    exit 1
fi

# playwright.config.js at project root
if [ ! -f "playwright.config.js" ]; then
    cp "$SCAFFOLD_DIR/playwright.config.js" "playwright.config.js"
    echo "Created playwright.config.js"
else
    echo "playwright.config.js already exists, skipping."
fi

# Tests/Playwright/helpers/
mkdir -p "Tests/Playwright/helpers"
for file in axe-helper.js common-checks.js; do
    if [ ! -f "Tests/Playwright/helpers/$file" ]; then
        cp "$SCAFFOLD_DIR/Tests/Playwright/helpers/$file" "Tests/Playwright/helpers/$file"
        echo "Created Tests/Playwright/helpers/$file"
    else
        echo "Tests/Playwright/helpers/$file already exists, skipping."
    fi
done

# Conditionally copy an .env file if an example file exists
[ -f .env.example ] && [ ! -f .env ] && cp -n .env.example .env

exit 0
